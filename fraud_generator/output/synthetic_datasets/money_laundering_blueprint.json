{
  "Fraud_Scenario_Name": "Money Laundering",
  "Description": "Illicit funds are passed through multiple transactions to obscure their origin and appear as legitimate income.",
  "Fraud_Type": "Financial Crime",
  "Dataset_Specifications": {
    "total_rows": 5000,
    "fraud_ratio": 0.33,
    "output_format": "csv",
    "date_range_start": "2022-01-01",
    "date_range_end": "2024-12-31",
    "num_users": 1000,
    "num_merchants": 200
  },
  "Normal_User_Profile": {
    "transaction_amount": {
      "distribution": "lognormal",
      "min": 10.0,
      "max": 5000.0,
      "mean": 200.0,
      "std": 150.0
    },
    "transactions_per_day": {
      "mean": 2.5,
      "std": 1.5,
      "max": 10
    },
    "active_hours": {
      "peak_start": 9,
      "peak_end": 17,
      "off_peak_weight": 0.05
    },
    "active_days": {
      "weekday_weight": 0.7,
      "weekend_weight": 0.3
    },
    "merchant_category_weights": {
      "Retail": 0.4,
      "Restaurant": 0.3,
      "Travel": 0.2,
      "Entertainment": 0.1
    },
    "currency_weights": {
      "USD": 0.9,
      "EUR": 0.05,
      "GBP": 0.05
    },
    "location_change_prob": 0.05,
    "device_change_prob": 0.02
  },
  "Fraud_Patterns": [
    {
      "pattern_name": "Initial Deposit",
      "description": "",
      "weight": 0.4,
      "sequence_type": "burst",
      "params": {
        "amount_min": 100.0,
        "amount_max": 1000.0,
        "amount_mean": 500.0,
        "amount_std": 200.0,
        "burst_min_txns": 3,
        "burst_max_txns": 10,
        "burst_window_mins": 15,
        "num_merchants": 2,
        "preferred_hours": [
          10,
          11,
          12
        ],
        "preferred_days": [
          5,
          6
        ],
        "same_device_prob": 0.9,
        "same_location_prob": 0.95,
        "foreign_ip_prob": 0.8,
        "round_amount_prob": 0.1,
        "velocity_txns_per_hour": 5.0
      }
    },
    {
      "pattern_name": "Layered Transactions",
      "description": "",
      "weight": 0.6,
      "sequence_type": "chain",
      "params": {
        "amount_min": 10.0,
        "amount_max": 500.0,
        "amount_mean": 200.0,
        "amount_std": 100.0,
        "burst_min_txns": 5,
        "burst_max_txns": 15,
        "burst_window_mins": 30,
        "num_merchants": 3,
        "preferred_hours": [
          9,
          10,
          11
        ],
        "preferred_days": [
          5,
          6
        ],
        "same_device_prob": 0.8,
        "same_location_prob": 0.9,
        "foreign_ip_prob": 0.85,
        "round_amount_prob": 0.2,
        "velocity_txns_per_hour": 10.0
      }
    }
  ],
  "Fraud_Injection_Rules": {
    "strategy": "dedicated_fraudsters",
    "fraud_user_ratio": 0.03,
    "max_fraud_txns_per_user": 120,
    "contaminate_normal_users": false,
    "contamination_prob": 0.0
  },
  "Sequence_Rules": {
    "enabled": true,
    "max_chain_length": 80,
    "inter_txn_gap_seconds": {
      "min": 5,
      "max": 120
    },
    "reuse_card_in_chain": true,
    "reuse_merchant_in_chain": true
  },
  "Anomaly_Signals": {
    "Initial Deposit": {
      "transaction_amount": "< 1000.0 (extremely low)",
      "velocity_per_hour": "> 5 transactions",
      "unique_cards_per_ip": "> 5",
      "foreign_ip_flag": "= 1",
      "hour_of_day": "9–14 (peak hours)"
    },
    "Layered Transactions": {
      "transaction_amount": "10–500, escalating sequence",
      "merchant_repeat": "same merchant 3–8x",
      "foreign_ip_flag": "= 1"
    }
  },
  "Column_Definitions": {
    "transaction_id": {
      "type": "uuid"
    },
    "timestamp": {
      "type": "datetime",
      "range": [
        "2022-01-01",
        "2024-12-31"
      ]
    },
    "user_id": {
      "type": "string",
      "cardinality": 1000
    },
    "card_number": {
      "type": "string",
      "format": "16-digit"
    },
    "bin_number": {
      "type": "string",
      "format": "first-6-digits-of-card"
    },
    "merchant_id": {
      "type": "string",
      "cardinality": 200
    },
    "merchant_category": {
      "type": "categorical",
      "values": [
        "Retail",
        "Restaurant",
        "Travel",
        "Entertainment"
      ]
    },
    "transaction_amount": {
      "type": "float",
      "min": 10.0,
      "max": 5000.0
    },
    "currency": {
      "type": "categorical",
      "values": [
        "USD",
        "EUR",
        "GBP"
      ]
    },
    "location": {
      "type": "string"
    },
    "device_id": {
      "type": "string"
    },
    "ip_address": {
      "type": "ipv4"
    },
    "foreign_ip_flag": {
      "type": "integer",
      "values": [
        0,
        1
      ]
    },
    "fraud_label": {
      "type": "integer",
      "values": [
        0,
        1
      ]
    }
  },
  "Validation_Constraints": {
    "transaction_amount": {
      "min": 10.0,
      "max": 50000.0
    },
    "fraud_ratio_actual": {
      "min": 0.01,
      "max": 0.99
    },
    "required_columns": [
      "transaction_id",
      "timestamp",
      "user_id",
      "card_number",
      "bin_number",
      "merchant_id",
      "merchant_category",
      "transaction_amount",
      "currency",
      "location",
      "device_id",
      "ip_address",
      "fraud_label"
    ]
  }
}